# Configuração do Supabase
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Configurações de desenvolvimento
NODE_ENV=development
VITE_APP_TITLE=Copiloto Focco Brasil
VITE_APP_VERSION=1.0.0

# ─── Testes E2E (Playwright) ───────────────────────────────────────────
# Usuários de teste por papel (cargo em profiles). Use contas dedicadas
# de QA — NÃO use contas de produção reais.
PLAYWRIGHT_VENDEDOR_EMAIL=vendedor.qa@focco.test
PLAYWRIGHT_VENDEDOR_PASS=
PLAYWRIGHT_GESTOR_EMAIL=gestor.qa@focco.test
PLAYWRIGHT_GESTOR_PASS=
PLAYWRIGHT_DIRETOR_EMAIL=diretor.qa@focco.test
PLAYWRIGHT_DIRETOR_PASS=